# ══════════════════════════════════════════════════════════════
# AS Code — Environment Configuration (Example)
# ══════════════════════════════════════════════════════════════

# Server
ASCODE_HOST=127.0.0.1
ASCODE_PORT=8000
ASCODE_LOG_LEVEL=INFO

# Models
ASCODE_MODELS_DIR=models
ASCODE_REASONING_MODEL_ID=gemma-3n-web
ASCODE_REASONING_MODEL_FILE=models/gemma/gemma-3n-E2B-it-int4.litertlm
ASCODE_REASONING_MODEL_VRAM_MB=1500
ASCODE_CODING_MODEL_ID=gemma-3n-code
ASCODE_CODING_MODEL_FILE=models/gemma/gemma-3n-E2B-it-int4.litertlm
ASCODE_CODING_MODEL_VRAM_MB=1500

# Provider
ASCODE_ACTIVE_PROVIDER=litert_cli
ASCODE_LITERT_BACKEND=gpu
ASCODE_ENABLE_SPECULATIVE_DECODING=true

# Inference
ASCODE_DEFAULT_TEMPERATURE=0.7
ASCODE_DEFAULT_MAX_TOKENS=1024
ASCODE_MAX_CONTEXT_LENGTH=2048

# Hardware Adaptive
ASCODE_MAX_VRAM_USAGE_MB=3200
ASCODE_MODEL_UNLOAD_TIMEOUT_SEC=300
ASCODE_ANTI_OOM_THRESHOLD_MB=500

# System Mode: ultra_light, balanced, performance
ASCODE_SYSTEM_MODE=balanced
